# ─────────────────────────────────────────────────────────────────────────────
# OSS RAG Stack — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development                        # development | production
LOG_LEVEL=DEBUG                            # DEBUG | INFO | WARNING | ERROR
ALLOWED_ORIGINS=http://localhost:3010,http://localhost:5173

# ── Claude API ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...               # Required — get at console.anthropic.com
CLAUDE_MODEL=claude-sonnet-4-6             # claude-sonnet-4-6 | claude-opus-4-6 | claude-haiku-4-5-20251001
CLAUDE_MAX_TOKENS=2048
CLAUDE_TEMPERATURE=0.0                     # 0.0 = deterministic, great for RAG

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2   # 384-dim, ~90MB, runs on CPU
# Other options:
#   sentence-transformers/all-mpnet-base-v2     (768-dim, better quality, slower)
#   sentence-transformers/multi-qa-mpnet-base-dot-v1  (good for Q&A)
EMBEDDING_DEVICE=cpu                        # cpu | cuda | mps (Apple Silicon)
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DIMENSIONS=384                    # Must match the model above

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION=documents
QDRANT_API_KEY=                            # Leave empty for local dev, set for prod

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PORT=5440
POSTGRES_DB=ragdb
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword              # Change in production!

# ── MinIO (S3-compatible object storage) ─────────────────────────────────────
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123          # Change in production!
MINIO_APP_USER=ragapp                      # App service account
MINIO_APP_PASSWORD=ragapp123               # Change in production!
MINIO_BUCKET=documents

# When deploying to a real S3-compatible service (AWS S3, GCS, Cloudflare R2):
# S3_ENDPOINT_URL=https://s3.amazonaws.com   (or blank for AWS)
# S3_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
# S3_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# S3_REGION=us-east-1

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production-use-random-32-char-string  # openssl rand -hex 32
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# ── RAG Tuning ────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=5                          # Number of chunks to retrieve per query
RETRIEVAL_SCORE_THRESHOLD=0.3             # Min similarity score (0-1)
CHUNK_SIZE=512                             # Tokens per chunk
CHUNK_OVERLAP=64                           # Overlap between chunks (sliding window)
USE_HYBRID_SEARCH=true                     # Dense + sparse (BM25) hybrid

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_PORT=3010
VITE_API_URL=http://localhost:8010
VITE_APP_TITLE=OSS RAG Chat
FRONTEND_BUILD_TARGET=development          # development | production

# ── OpenTelemetry (optional) ──────────────────────────────────────────────────
# Set to export traces to a local Jaeger, Grafana Tempo, or any OTLP collector.
# Leave unset (default) to disable tracing with zero overhead.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── Ports ─────────────────────────────────────────────────────────────────────
BACKEND_PORT=8010
NGINX_PORT=8090
ADMINER_PORT=8011
